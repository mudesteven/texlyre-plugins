# Copy to .env and edit before running docker-compose

# Fast local storage path (required)
LOCAL_ROOT=/var/lib/texlyre

# google-drive-ocamlfuse mount path (optional — enables Drive backup)
# Mount with: google-drive-ocamlfuse /mnt/gdrive
# Then set:
# FUSE_ROOT=/mnt/gdrive/texlyre

# Server
PORT=7331
SECRET=change-me-please-use-a-long-random-string

# Comma-separated list of allowed browser origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Sync intervals (seconds)
LOCAL_SYNC_INTERVAL=2
FUSE_POLL_INTERVAL=10
